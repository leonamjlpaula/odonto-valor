# Copie para .env.local para desenvolvimento local com Docker
# cp .env.local.example .env.local

# Database (PostgreSQL local via docker-compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/precifica"

# NextAuth
NEXTAUTH_SECRET="dev-secret-troque-em-producao"
NEXTAUTH_URL="http://localhost:3000"

# Email (Mailhog local — UI em http://localhost:8025)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Precifica <noreply@precifica.local>"
